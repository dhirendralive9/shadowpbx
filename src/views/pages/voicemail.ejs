<%- include('../partials/head', { title: 'Voicemail', active: 'voicemail' }) %>
<div class="sec-head">
  <span class="sec-title">Voicemail inbox</span>
</div>
<div style="display:flex;gap:8px;margin-bottom:14px">
  <select class="form-select" style="max-width:160px" id="vm-ext" onchange="loadVM()">
    <option value="">Select extension...</option>
  </select>
  <span class="muted" style="font-size:12px;line-height:34px" id="vm-info"></span>
</div>
<table class="tbl">
  <thead><tr><th>Status</th><th>Caller</th><th>Duration</th><th>Date</th><th>Actions</th></tr></thead>
  <tbody id="vm-body"><tr><td colspan="5" class="empty">Select an extension to view voicemail</td></tr></tbody>
</table>
<script>
const API='/api',KEY='<%= apiKey %>',H={'X-API-Key':KEY};
function dur(s){if(!s)return'-';return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0')}
function fmtTime(t){if(!t)return'';const d=new Date(t);return d.toLocaleDateString([],{month:'short',day:'numeric'})+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}

async function init(){
  const d=await(await fetch(API+'/extensions',{headers:H})).json();
  if(d.success){
    const sel=document.getElementById('vm-ext');
    d.extensions.forEach(e=>{const o=document.createElement('option');o.value=e.extension;o.textContent=e.extension+' — '+(e.name||'');sel.appendChild(o)});
  }
}

async function loadVM(){
  const ext=document.getElementById('vm-ext').value;
  const b=document.getElementById('vm-body');
  if(!ext){b.innerHTML='<tr><td colspan="5" class="empty">Select an extension</td></tr>';return}
  const d=await(await fetch(API+'/voicemail/'+ext,{headers:H})).json();
  if(d.success&&d.messages&&d.messages.length){
    document.getElementById('vm-info').textContent=d.unread+' unread of '+d.messages.length;
    b.innerHTML=d.messages.map(m=>`<tr>
      <td><span class="pill ${m.read?'p-gray':'p-warn'}">${m.read?'read':'new'}</span></td>
      <td>${m.callerID||'unknown'}</td>
      <td class="mono">${dur(m.duration)}</td>
      <td class="muted" style="font-size:11px">${fmtTime(m.createdAt)}</td>
      <td>
        <button class="btn btn-sm" onclick="playVM('${ext}','${m.messageId}')">Play</button>
        <button class="btn btn-sm" onclick="markRead('${ext}','${m.messageId}')">Mark read</button>
        <button class="btn btn-sm btn-danger" onclick="delVM('${ext}','${m.messageId}')">Delete</button>
      </td>
    </tr>`).join('');
  }else{
    document.getElementById('vm-info').textContent='no messages';
    b.innerHTML='<tr><td colspan="5" class="empty">No voicemail for '+ext+'</td></tr>';
  }
}

function playVM(ext,id){
  window.open(API+'/voicemail/'+ext+'/'+id+'/audio?apikey='+KEY,'_blank');
}
async function markRead(ext,id){
  await fetch(API+'/voicemail/'+ext+'/'+id+'/read',{method:'POST',headers:H});loadVM();
}
async function delVM(ext,id){
  if(!confirm('Delete this voicemail?'))return;
  await fetch(API+'/voicemail/'+ext+'/'+id,{method:'DELETE',headers:H});loadVM();
}
init();
</script>
<%- include('../partials/foot') %>
