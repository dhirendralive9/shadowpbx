var ICON_PLAY = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
var ICON_PAUSE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
var currentAudio = null, currentBtn = null;
function playAudio(filename, btn) {
  if (currentAudio && currentBtn === btn) { if (currentAudio.paused) { currentAudio.play(); btn.innerHTML = ICON_PAUSE; } else { currentAudio.pause(); btn.innerHTML = ICON_PLAY; } return; }
  if (currentAudio) { currentAudio.pause(); if (currentBtn) currentBtn.innerHTML = ICON_PLAY; }
  var a = new Audio(API + '/audio/play/' + encodeURIComponent(filename));
  a.onended = function() { btn.innerHTML = ICON_PLAY; currentAudio = null; currentBtn = null; };
  a.onerror = function() { btn.innerHTML = ICON_PLAY; showToast('Could not play', true); currentAudio = null; currentBtn = null; };
  a.play(); btn.innerHTML = ICON_PAUSE; currentAudio = a; currentBtn = btn;
}
async function renameAudio(oldName) {
  var baseName = oldName.replace(/\.[^.]+$/, '');
  var newName = prompt('Rename "' + oldName + '" to:', baseName);
  if (!newName || newName === baseName) return;
  var r = await fetch(API + '/audio/rename', { method: 'POST', headers: J, body: JSON.stringify({ oldName: oldName, newName: newName }) });
  var d = await r.json();
  if (d.success) { showToast('Renamed to ' + d.newName); loadAudioFiles(); } else showToast(d.error || 'Rename failed', true);
}
async function deleteAudio(filename) {
  if (!confirm('Delete "' + filename + '"?\n\nIf used by an IVR or MOH, it will stop working.')) return;
  var r = await fetch(API + '/audio/' + encodeURIComponent(filename), { method: 'DELETE', headers: H });
  var d = await r.json();
  if (d.success) { showToast(filename + ' deleted'); loadAudioFiles(); } else showToast(d.error || 'Delete failed', true);
}
async function uploadAudioFile(input) {
  if (!input.files || !input.files[0]) return;
  var formData = new FormData(); formData.append('file', input.files[0]);
  try {
    var r = await fetch(API + '/audio/upload', { method: 'POST', headers: { 'X-API-Key': KEY }, body: formData });
    var d = await r.json();
    if (d.success) { showToast('Uploaded: ' + d.originalName); loadAudioFiles(); } else showToast(d.error || 'Upload failed', true);
  } catch (e) { showToast('Upload failed', true); }
  input.value = '';
}

