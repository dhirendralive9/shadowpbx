  var d = await (await fetch(API + '/dnc/check/' + q, { headers: H })).json();
  var c = document.getElementById('dnc-list');
  if (d.success && d.isDnc && d.details) {
    var n = d.details;
    c.innerHTML = '<table class="tbl"><thead><tr><th>Phone</th><th>Reason</th><th>Source</th><th>Added by</th><th>Date</th><th></th></tr></thead><tbody>' +
      '<tr><td class="mono" style="font-weight:600">' + esc(n.phone) + '</td>' +
      '<td style="font-size:12px">' + esc(n.reason || '—') + '</td>' +
      '<td><span class="pill p-gray" style="font-size:10px">' + esc(n.source || 'admin') + '</span></td>' +
      '<td style="font-size:12px">' + esc(n.addedBy || '—') + '</td>' +
      '<td style="font-size:11px">' + (n.createdAt ? new Date(n.createdAt).toLocaleDateString() : '—') + '</td>' +
      '<td style="text-align:right"><button class="btn btn-sm btn-danger" onclick="deleteDnc(\'' + esc(n.phone) + '\')">Remove</button></td></tr>' +
      '</tbody></table>';
    document.getElementById('dnc-summary').textContent = 'Found: ' + q;
  } else {
    c.innerHTML = '<div class="card"><div class="empty">' + esc(q) + ' is NOT on the DNC list</div></div>';
    document.getElementById('dnc-summary').textContent = 'Not found';
  }
}

async function importDnc(e) {
  e.preventDefault();
  var file = document.getElementById('dnc-file').files[0];
  if (!file) return;
  var fd = new FormData(); fd.append('file', file);
  var d = await (await fetch(API + '/dnc/import', { method: 'POST', headers: { 'X-API-Key': KEY }, body: fd })).json();
  if (d.success) {
    document.getElementById('dnc-import-result').innerHTML =
      '<div style="padding:8px;background:var(--bg-surface);border-radius:var(--radius);font-size:12px">' +
      '<b>Import complete:</b> ' + d.imported + ' imported, ' + d.duplicates + ' duplicates, ' + d.invalid + ' invalid</div>';
    showToast(d.imported + ' numbers added to DNC');
    loadDnc();
  } else {
    document.getElementById('dnc-import-result').innerHTML = '<div style="color:var(--color-error);font-size:12px">' + esc(d.error) + '</div>';
  }
}

// ─── Init ───
var initTab = window.location.hash.replace('#', '') || 'blocklist';
if (['blocklist', 'audio', 'sipdomains', 'dnc', 'users', 'maintenance', 'backup', 'system'].indexOf(initTab) === -1) initTab = 'blocklist';
switchTab(initTab);
</script>
