<%- include('../partials/head', { title: 'Settings', active: 'settings' }) %>

<!-- Sub-navigation -->
<div class="sub-tabs">
  <a href="#blocklist" class="sub-tab active" data-tab="blocklist" onclick="switchTab('blocklist')">Blocklist</a>
  <a href="#audio" class="sub-tab" data-tab="audio" onclick="switchTab('audio')">Audio library</a>
  <a href="#sipdomains" class="sub-tab" data-tab="sipdomains" onclick="switchTab('sipdomains')">SIP Domains</a>
  <a href="#dnc" class="sub-tab" data-tab="dnc" onclick="switchTab('dnc')">DNC list</a>
  <a href="#users" class="sub-tab" data-tab="users" onclick="switchTab('users')">Users</a>
  <a href="#maintenance" class="sub-tab" data-tab="maintenance" onclick="switchTab('maintenance')">Maintenance</a>
  <a href="#backup" class="sub-tab" data-tab="backup" onclick="switchTab('backup')">Backup</a>
  <a href="#system" class="sub-tab" data-tab="system" onclick="switchTab('system')">System</a>
</div>

<style>
.settings-tab {
  padding: 10px 18px; font-size: 13px; color: var(--text-tertiary);
  cursor: pointer; border-bottom: 2px solid transparent;
  text-decoration: none; transition: color 0.15s;
}
.settings-tab:hover { color: var(--text-secondary); text-decoration: none; }
.settings-tab.active { color: var(--text-primary); border-bottom-color: var(--accent); }
.settings-panel { display: none; }
.settings-panel.active { display: block; }
.stat-card { background: var(--bg-surface); border-radius: var(--radius); padding: 16px; border: 0.5px solid var(--border); }
.stat-val { font-size: 24px; font-weight: 600; margin-bottom: 2px; }
.stat-label { font-size: 11px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.4px; }
.stat-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 2px; }
.db-bar { height: 6px; border-radius: 3px; background: var(--bg-tertiary); margin-top: 6px; overflow: hidden; }
.db-bar-fill { height: 100%; border-radius: 3px; background: var(--accent); transition: width 0.3s; }
</style>

<!-- ═══════════════════ BLOCKLIST ═══════════════════ -->
<div id="panel-blocklist" class="settings-panel active">
  <div class="sec-head">
    <span class="sec-title">Blocked numbers</span>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="muted" style="font-size:11px" id="bl-summary"></span>
      <button class="btn btn-sm" onclick="showBlockAdd()">+ Block a number</button>
    </div>
  </div>

  <div id="block-add" style="display:none;margin-bottom:16px" class="card">
    <form onsubmit="addBlock(event)">
      <div class="grid-3" style="margin-bottom:0">
        <div class="form-group"><label class="form-label">Phone number</label><input class="form-input" id="bl-number" placeholder="919778988634" required></div>
        <div class="form-group"><label class="form-label">Reason (optional)</label><input class="form-input" id="bl-reason" placeholder="Spam / Telemarketer / etc."></div>
        <div class="form-group" style="display:flex;align-items:flex-end">
          <div style="display:flex;gap:8px">
            <button type="submit" class="btn btn-primary btn-sm">Block</button>
            <button type="button" class="btn btn-sm" onclick="document.getElementById('block-add').style.display='none'">Cancel</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <table class="tbl">
    <thead><tr><th>Number</th><th>Reason</th><th>Blocked by</th><th>Date</th><th></th></tr></thead>
    <tbody id="bl-body"><tr><td colspan="5" class="empty">Loading...</td></tr></tbody>
  </table>
</div>

<!-- ═══════════════════ AUDIO LIBRARY ═══════════════════ -->
<div id="panel-audio" class="settings-panel">
  <div class="sec-head">
    <span class="sec-title">Audio library</span>
    <div style="display:flex;gap:8px;align-items:center">
      <span class="muted" style="font-size:11px" id="audio-summary"></span>
      <button class="btn btn-sm" onclick="document.getElementById('audio-upload-settings').click()">Upload audio</button>
      <input type="file" id="audio-upload-settings" accept=".wav,.mp3" style="display:none" onchange="uploadAudioFile(this)">
    </div>
  </div>
  <p class="muted" style="font-size:11px;margin-bottom:10px">Audio files used for IVR greetings, MOH, and voicemail greetings. Uploaded files are auto-converted to 8kHz mono PCM WAV.</p>

  <table class="tbl">
    <thead><tr><th>Filename</th><th>Size</th><th>Modified</th><th></th></tr></thead>
    <tbody id="audio-body"><tr><td colspan="4" class="empty">Loading...</td></tr></tbody>
  </table>
</div>

<!-- ═══════════════════ SIP DOMAINS ═══════════════════ -->
<div id="panel-sipdomains" class="settings-panel">
  <div class="sec-head">
    <span class="sec-title">Allowed SIP sources</span>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="muted" style="font-size:11px" id="sd-summary"></span>
      <button class="btn btn-sm" onclick="showSipDomainAdd()">+ Add domain / IP</button>
    </div>
  </div>

  <div style="margin-bottom:12px;padding:10px;background:var(--bg-surface);border-radius:var(--radius);font-size:12px;color:var(--text-secondary)">
    Whitelist SIP domains (e.g. <span class="mono">sip2sip.info</span>) and IP addresses (e.g. <span class="mono">51.77.118.142</span>) that are allowed to call your extensions.
    Extensions must also have <strong>"Ext. SIP"</strong> enabled to receive external calls. Calls from unlisted sources are rejected.
  </div>

  <div id="sd-add" style="display:none;margin-bottom:16px" class="card">
    <form onsubmit="saveSipDomain(event)" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
      <div class="form-group" style="flex:1;min-width:180px"><label class="form-label">Domain or IP address</label><input class="form-input" id="sd-domain" placeholder="sip2sip.info or 51.77.118.142" required></div>
      <div class="form-group" style="flex:1;min-width:180px"><label class="form-label">Friendly name</label><input class="form-input" id="sd-name" placeholder="Client PBX / SIP Provider"></div>
      <div class="form-group" style="flex:1;min-width:180px"><label class="form-label">Description</label><input class="form-input" id="sd-desc" placeholder="Yeastar PBX at client office"></div>
      <div class="form-group"><button type="submit" class="btn btn-primary btn-sm">Add</button></div>
      <div class="form-group"><button type="button" class="btn btn-sm" onclick="document.getElementById('sd-add').style.display='none'">Cancel</button></div>
    </form>
  </div>

  <div id="sd-list"></div>
</div>

<!-- ═══════════════════ USERS (embedded) ═══════════════════ -->
<div id="panel-users" class="settings-panel">
  <div class="sec-head">
    <span class="sec-title">User management</span>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="muted" style="font-size:11px" id="user-summary"></span>
      <button class="btn btn-sm" onclick="document.getElementById('user-add').style.display=document.getElementById('user-add').style.display==='none'?'block':'none'">+ Add user</button>
    </div>
  </div>

  <div id="user-add" style="display:none;margin-bottom:16px" class="card">
    <form onsubmit="addUser(event)" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
      <div class="form-group" style="flex:1;min-width:140px"><label class="form-label">Username</label><input class="form-input" id="u-username" required></div>
      <div class="form-group" style="flex:1;min-width:140px"><label class="form-label">Name</label><input class="form-input" id="u-name" required></div>
      <div class="form-group" style="flex:1;min-width:140px"><label class="form-label">Password</label><input class="form-input" id="u-password" type="password" required></div>
      <div class="form-group" style="min-width:120px"><label class="form-label">Role</label>
        <select class="form-select" id="u-role"><option value="admin">Admin</option><option value="supervisor">Supervisor</option><option value="agent">Agent</option></select>
      </div>
      <div class="form-group" style="min-width:100px"><label class="form-label">Extension</label><input class="form-input" id="u-ext" placeholder="2001"></div>
      <div class="form-group"><button type="submit" class="btn btn-primary btn-sm">Create</button></div>
      <div class="form-group"><button type="button" class="btn btn-sm" onclick="document.getElementById('user-add').style.display='none'">Cancel</button></div>
    </form>
  </div>

  <div id="user-list"></div>
</div>

<!-- ═══════════════════ DNC (DO NOT CALL) ═══════════════════ -->
<div id="panel-dnc" class="settings-panel">
  <div class="sec-head">
    <span class="sec-title">Do Not Call list</span>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="muted" style="font-size:11px" id="dnc-summary"></span>
      <button class="btn btn-sm" onclick="document.getElementById('dnc-add').style.display=document.getElementById('dnc-add').style.display==='none'?'block':'none'">+ Add number</button>
      <button class="btn btn-sm" onclick="document.getElementById('dnc-import').style.display=document.getElementById('dnc-import').style.display==='none'?'block':'none'">Import CSV</button>
    </div>
  </div>

  <div style="margin-bottom:12px;padding:10px;background:var(--bg-surface);border-radius:var(--radius);font-size:12px;color:var(--text-secondary)">
    Numbers on this list will never be dialed by any campaign. Numbers are checked at CSV import time and again at dial time.
    Agents can also add numbers by setting a lead's disposition to <b>"DNC"</b>.
  </div>

  <!-- Add single number -->
  <div id="dnc-add" style="display:none;margin-bottom:16px" class="card">
    <form onsubmit="addDnc(event)" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
      <div class="form-group" style="flex:1;min-width:160px"><label class="form-label">Phone number</label><input class="form-input" id="dnc-phone" placeholder="5551234567" required></div>
      <div class="form-group" style="flex:1;min-width:160px"><label class="form-label">Reason</label><input class="form-input" id="dnc-reason" placeholder="Customer requested"></div>
      <div class="form-group"><button type="submit" class="btn btn-primary btn-sm">Add</button></div>
      <div class="form-group"><button type="button" class="btn btn-sm" onclick="document.getElementById('dnc-add').style.display='none'">Cancel</button></div>
    </form>
  </div>

  <!-- CSV import -->
  <div id="dnc-import" style="display:none;margin-bottom:16px" class="card">
    <form onsubmit="importDnc(event)">
      <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap">
        <div class="form-group" style="flex:1;min-width:200px"><label class="form-label">CSV file (phone numbers in first column)</label>
          <input class="form-input" type="file" id="dnc-file" accept=".csv,.txt" required></div>
        <div class="form-group"><button type="submit" class="btn btn-primary btn-sm">Import</button></div>
        <div class="form-group"><button type="button" class="btn btn-sm" onclick="document.getElementById('dnc-import').style.display='none'">Cancel</button></div>
      </div>
    </form>
    <div id="dnc-import-result" style="margin-top:8px"></div>
  </div>

  <!-- Search -->
  <div style="margin-bottom:12px;display:flex;gap:8px">
    <input class="form-input" id="dnc-search" placeholder="Search phone number..." style="max-width:250px" onkeyup="if(event.key==='Enter')searchDnc()">
    <button class="btn btn-sm" onclick="searchDnc()">Search</button>
    <button class="btn btn-sm" onclick="document.getElementById('dnc-search').value='';loadDnc()">Clear</button>
  </div>

  <div id="dnc-list"></div>
</div>

<!-- ═══════════════════ MAINTENANCE ═══════════════════ -->
<div id="panel-maintenance" class="settings-panel">

  <!-- Storage Stats -->
  <div class="sec-head"><span class="sec-title">Storage usage</span></div>
  <div class="grid-3" style="margin-bottom:24px">
    <div class="stat-card">
      <div class="stat-val" id="st-recordings">—</div>
      <div class="stat-label">Recordings (WAV)</div>
      <div class="stat-sub" id="st-recordings-sub"></div>
    </div>
    <div class="stat-card">
      <div class="stat-val" id="st-pcaps">—</div>
      <div class="stat-label">Source pcaps</div>
      <div class="stat-sub" id="st-pcaps-sub"></div>
    </div>
    <div class="stat-card">
      <div class="stat-val" id="st-total">—</div>
      <div class="stat-label">Total disk usage</div>
      <div class="stat-sub" id="st-total-sub"></div>
    </div>
  </div>

  <!-- Recording Retention -->
  <div class="sec-head"><span class="sec-title">Recording retention</span></div>
  <div class="card" style="margin-bottom:24px">
    <p class="muted" style="font-size:12px;margin-bottom:12px">Automatically delete old call recordings and pcap files after a set period. The cleanup runs daily via the recording worker service.</p>
    <div class="grid-3" style="margin-bottom:0">
      <div class="form-group">
        <label class="form-label">Auto-delete recordings</label>
        <select class="form-select" id="ret-enabled" onchange="toggleRetention()">
          <option value="false">Disabled — keep forever</option>
          <option value="true">Enabled — delete after period</option>
        </select>
      </div>
      <div class="form-group" id="ret-days-group" style="display:none">
        <label class="form-label">Delete recordings older than</label>
        <select class="form-select" id="ret-days">
          <option value="15">15 days</option>
          <option value="30">30 days</option>
          <option value="60">60 days</option>
          <option value="90" selected>90 days</option>
          <option value="180">180 days</option>
          <option value="365">1 year</option>
        </select>
      </div>
      <div class="form-group" id="ret-options-group" style="display:none">
        <label class="form-label">What to delete</label>
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;padding:4px 0">
          <input type="checkbox" id="ret-wav" checked> WAV recordings
        </label>
        <label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;padding:4px 0">
          <input type="checkbox" id="ret-pcap" checked> Source pcap files
        </label>
      </div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;margin-top:12px">
      <button class="btn btn-primary btn-sm" onclick="saveRetention()">Save</button>
      <button class="btn btn-sm" onclick="runCleanupNow()" id="cleanup-btn">Run cleanup now</button>
      <span class="muted" style="font-size:11px" id="ret-last-cleanup"></span>
    </div>
  </div>
</div>

<!-- ═══════════════════ BACKUP ═══════════════════ -->
<div id="panel-backup" class="settings-panel">

  <!-- Database Overview -->
  <div class="sec-head"><span class="sec-title">Database overview</span></div>
  <div class="grid-3" style="margin-bottom:8px" id="db-overview-cards">
    <div class="stat-card">
      <div class="stat-val" id="db-total-size">—</div>
      <div class="stat-label">Total database size</div>
      <div class="stat-sub" id="db-total-detail"></div>
    </div>
    <div class="stat-card">
      <div class="stat-val" id="db-collections">—</div>
      <div class="stat-label">Collections</div>
      <div class="stat-sub" id="db-collections-detail"></div>
    </div>
    <div class="stat-card">
      <div class="stat-val" id="db-documents">—</div>
      <div class="stat-label">Total documents</div>
      <div class="stat-sub" id="db-documents-detail"></div>
    </div>
  </div>

  <!-- Data vs Index split -->
  <div class="card" style="margin-bottom:24px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
      <span style="font-size:12px;font-weight:500">Storage breakdown</span>
      <span class="muted" style="font-size:11px" id="db-breakdown-label"></span>
    </div>
    <div style="display:flex;gap:4px;height:10px;border-radius:5px;overflow:hidden;background:var(--bg-tertiary)">
      <div id="db-bar-data" style="background:var(--accent);transition:width 0.4s;border-radius:5px 0 0 5px"></div>
      <div id="db-bar-index" style="background:var(--text-tertiary);transition:width 0.4s;border-radius:0 5px 5px 0"></div>
    </div>
    <div style="display:flex;gap:16px;margin-top:6px">
      <span style="font-size:11px;display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:2px;background:var(--accent);display:inline-block"></span> Data: <span id="db-data-size">—</span></span>
      <span style="font-size:11px;display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:2px;background:var(--text-tertiary);display:inline-block"></span> Indexes: <span id="db-index-size">—</span></span>
    </div>
  </div>

  <!-- Collection Details Table -->
  <div class="sec-head"><span class="sec-title">Collections</span></div>
  <table class="tbl" style="margin-bottom:24px">
    <thead>
      <tr>
        <th>Collection</th>
        <th style="text-align:right">Documents</th>
        <th style="text-align:right">Data size</th>
        <th style="text-align:right">Avg doc size</th>
        <th style="text-align:right">Indexes</th>
        <th style="text-align:right">Index size</th>
        <th style="width:100px"></th>
      </tr>
    </thead>
    <tbody id="db-collections-body"><tr><td colspan="7" class="empty">Loading...</td></tr></tbody>
  </table>

  <!-- Backup Management -->
  <div class="sec-head">
    <span class="sec-title">Backup management</span>
    <div style="display:flex;gap:8px;align-items:center">
      <span class="muted" style="font-size:11px" id="backup-last"></span>
      <button class="btn btn-primary btn-sm" onclick="createBackup()" id="backup-btn">Create backup now</button>
    </div>
  </div>

  <div class="card" style="margin-bottom:16px">
    <div class="grid-3" style="margin-bottom:0">
      <div class="form-group">
        <label class="form-label">Backup retention</label>
        <select class="form-select" id="bk-retain">
          <option value="3">Keep 3 days</option>
          <option value="7" selected>Keep 7 days</option>
          <option value="14">Keep 14 days</option>
          <option value="30">Keep 30 days</option>
          <option value="90">Keep 90 days</option>
        </select>
      </div>
      <div class="form-group" style="display:flex;align-items:flex-end">
        <button class="btn btn-sm" onclick="saveBackupSettings()">Save</button>
      </div>
    </div>
  </div>

  <table class="tbl">
    <thead><tr><th>Backup file</th><th style="text-align:right">Size</th><th>Created</th><th></th></tr></thead>
    <tbody id="backup-body"><tr><td colspan="4" class="empty">No backups yet</td></tr></tbody>
  </table>
</div>

<!-- ═══════════════════ SYSTEM ═══════════════════ -->
<div id="panel-system" class="settings-panel">
  <div class="sec-head"><span class="sec-title">System information</span></div>
  <div class="card">
    <div class="grid-3">
      <div><span class="muted" style="font-size:11px">Version</span><div style="font-size:14px;font-weight:500">ShadowPBX v2.0</div></div>
      <div><span class="muted" style="font-size:11px">Uptime</span><div style="font-size:14px;font-weight:500" id="sys-uptime">—</div></div>
      <div><span class="muted" style="font-size:11px">Server time</span><div style="font-size:14px;font-weight:500" id="sys-time">—</div></div>
    </div>
  </div>
  <div style="margin-top:20px">
    <div class="sec-head"><span class="sec-title">Quick actions</span></div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <a href="https://github.com/dhirendralive9/shadowpbx" target="_blank" class="btn btn-sm">GitHub repo</a>
    </div>
  </div>
</div>

<script>
var API = '/api', KEY = '<%= apiKey %>', H = { 'X-API-Key': KEY };
var J = { 'X-API-Key': KEY, 'Content-Type': 'application/json' };
var currentUser = '<%= typeof user !== "undefined" ? user : "admin" %>';

function esc(s) { if (!s) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function fmtTime(t) { if (!t) return ''; return new Date(t).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' }) + ' ' + new Date(t).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }); }
function showToast(msg, isError) {
  var el = document.createElement('div');
  el.className = 'toast ' + (isError ? 'toast-error' : 'toast-success');
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(function() { el.remove(); }, 3000);
}

// ─── Tab switching ───
function switchTab(tab) {
  document.querySelectorAll('.sub-tab[data-tab]').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.settings-panel').forEach(function(p) { p.classList.remove('active'); });
  var tabEl = document.querySelector('.sub-tab[data-tab="' + tab + '"]');
  var panelEl = document.getElementById('panel-' + tab);
  if (tabEl) tabEl.classList.add('active');
  if (panelEl) panelEl.classList.add('active');
  window.location.hash = tab;

  if (tab === 'blocklist') loadBlocklist();
  if (tab === 'audio') loadAudioFiles();
  if (tab === 'sipdomains') loadSipDomains();
  if (tab === 'dnc') loadDnc();
  if (tab === 'users') loadUsers();
  if (tab === 'maintenance') { loadSettings(); loadStorage(); }
  if (tab === 'backup') { loadDbStats(); loadBackups(); loadSettings(); }
  if (tab === 'system') loadSystem();
}

// ═══════════════════ BLOCKLIST ═══════════════════
function showBlockAdd() {
  document.getElementById('bl-number').value = '';
  document.getElementById('bl-reason').value = '';
  document.getElementById('block-add').style.display = 'block';
}
async function loadBlocklist() {
  try {
    var d = await (await fetch(API + '/blocklist', { headers: H })).json();
    var b = document.getElementById('bl-body');
    if (d.success && d.blocked && d.blocked.length) {
      document.getElementById('bl-summary').textContent = d.blocked.length + ' blocked';
      b.innerHTML = d.blocked.map(function(n) {
        return '<tr><td class="mono" style="font-weight:500">' + esc(n.number) + '</td>' +
          '<td class="muted">' + esc(n.reason || '—') + '</td>' +
          '<td class="muted" style="font-size:11px">' + esc(n.blockedBy || '—') + '</td>' +
          '<td class="muted" style="font-size:11px">' + fmtTime(n.createdAt) + '</td>' +
          '<td><button class="btn btn-sm" onclick="unblock(\'' + esc(n.number) + '\')">Unblock</button></td></tr>';
      }).join('');
    } else {
      document.getElementById('bl-summary').textContent = '';
      b.innerHTML = '<tr><td colspan="5" class="empty">No blocked numbers</td></tr>';
    }
  } catch (e) { console.error('blocklist', e); }
}
async function addBlock(e) {
  e.preventDefault();
  var number = document.getElementById('bl-number').value.trim();
  var reason = document.getElementById('bl-reason').value.trim();
  var r = await fetch(API + '/blocklist', { method: 'POST', headers: J, body: JSON.stringify({ number: number, reason: reason, blockedBy: currentUser }) });
  var d = await r.json();
  if (d.success) { document.getElementById('block-add').style.display = 'none'; showToast(number + ' blocked'); loadBlocklist(); }
  else showToast(d.error || 'Failed', true);
}
async function unblock(number) {
  if (!confirm('Unblock ' + number + '?')) return;
  await fetch(API + '/blocklist/' + number, { method: 'DELETE', headers: H });
