<%- include('../partials/head', { title: 'Settings', active: 'settings' }) %>

<!-- Sub-navigation -->
<div style="display:flex;gap:0;border-bottom:0.5px solid var(--border);margin-bottom:20px">
  <a href="#blocklist" class="settings-tab active" data-tab="blocklist" onclick="switchTab('blocklist')">Blocklist</a>
  <a href="#audio" class="settings-tab" data-tab="audio" onclick="switchTab('audio')">Audio library</a>
  <a href="#system" class="settings-tab" data-tab="system" onclick="switchTab('system')">System</a>
</div>

<style>
.settings-tab {
  padding: 10px 18px; font-size: 13px; color: var(--text-tertiary);
  cursor: pointer; border-bottom: 2px solid transparent;
  text-decoration: none; transition: color 0.15s;
}
.settings-tab:hover { color: var(--text-secondary); text-decoration: none; }
.settings-tab.active { color: var(--text-primary); border-bottom-color: var(--accent); }
.settings-panel { display: none; }
.settings-panel.active { display: block; }
</style>

<!-- ═══════════════════ BLOCKLIST ═══════════════════ -->
<div id="panel-blocklist" class="settings-panel active">
  <div class="sec-head">
    <span class="sec-title">Blocked numbers</span>
    <div style="display:flex;align-items:center;gap:10px">
      <span class="muted" style="font-size:11px" id="bl-summary"></span>
      <button class="btn btn-sm" onclick="showBlockAdd()">+ Block a number</button>
    </div>
  </div>

  <div id="block-add" style="display:none;margin-bottom:16px" class="card">
    <form onsubmit="addBlock(event)">
      <div class="grid-3" style="margin-bottom:0">
        <div class="form-group"><label class="form-label">Phone number</label><input class="form-input" id="bl-number" placeholder="919778988634" required></div>
        <div class="form-group"><label class="form-label">Reason (optional)</label><input class="form-input" id="bl-reason" placeholder="Spam / Telemarketer / etc."></div>
        <div class="form-group" style="display:flex;align-items:flex-end">
          <div style="display:flex;gap:8px">
            <button type="submit" class="btn btn-primary btn-sm">Block</button>
            <button type="button" class="btn btn-sm" onclick="document.getElementById('block-add').style.display='none'">Cancel</button>
          </div>
        </div>
      </div>
    </form>
  </div>

  <table class="tbl">
    <thead><tr><th>Number</th><th>Reason</th><th>Blocked by</th><th>Date</th><th></th></tr></thead>
    <tbody id="bl-body"><tr><td colspan="5" class="empty">Loading...</td></tr></tbody>
  </table>
</div>

<!-- ═══════════════════ AUDIO LIBRARY ═══════════════════ -->
<div id="panel-audio" class="settings-panel">
  <div class="sec-head">
    <span class="sec-title">Audio library</span>
    <div style="display:flex;gap:8px;align-items:center">
      <span class="muted" style="font-size:11px" id="audio-summary"></span>
      <button class="btn btn-sm" onclick="document.getElementById('audio-upload-settings').click()">Upload audio</button>
      <input type="file" id="audio-upload-settings" accept=".wav,.mp3" style="display:none" onchange="uploadAudioFile(this)">
    </div>
  </div>
  <p class="muted" style="font-size:11px;margin-bottom:10px">Audio files used for IVR greetings, MOH, and voicemail greetings. Uploaded files are auto-converted to 8kHz mono PCM WAV.</p>

  <table class="tbl">
    <thead><tr><th>Filename</th><th>Size</th><th>Modified</th><th></th></tr></thead>
    <tbody id="audio-body"><tr><td colspan="4" class="empty">Loading...</td></tr></tbody>
  </table>
</div>

<!-- ═══════════════════ SYSTEM ═══════════════════ -->
<div id="panel-system" class="settings-panel">
  <div class="sec-head">
    <span class="sec-title">System information</span>
  </div>
  <div class="card">
    <div class="grid-3">
      <div><span class="muted" style="font-size:11px">Version</span><div style="font-size:14px;font-weight:500">ShadowPBX v2.0</div></div>
      <div><span class="muted" style="font-size:11px">Uptime</span><div style="font-size:14px;font-weight:500" id="sys-uptime">—</div></div>
      <div><span class="muted" style="font-size:11px">Server time</span><div style="font-size:14px;font-weight:500" id="sys-time">—</div></div>
    </div>
  </div>

  <div style="margin-top:20px">
    <div class="sec-head"><span class="sec-title">Quick actions</span></div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <a href="https://github.com/dhirendralive9/shadowpbx" target="_blank" class="btn btn-sm">GitHub repo</a>
    </div>
  </div>
</div>

<script>
var API = '/api', KEY = '<%= apiKey %>', H = { 'X-API-Key': KEY };
var J = { 'X-API-Key': KEY, 'Content-Type': 'application/json' };
var currentUser = '<%= typeof user !== "undefined" ? user : "admin" %>';

function esc(s) { if (!s) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
function fmtTime(t) { if (!t) return ''; return new Date(t).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' }) + ' ' + new Date(t).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }); }
function showToast(msg, isError) {
  var el = document.createElement('div');
  el.className = 'toast ' + (isError ? 'toast-error' : 'toast-success');
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(function() { el.remove(); }, 3000);
}

// ─── Sub-tab switching ───
function switchTab(tab) {
  document.querySelectorAll('.settings-tab').forEach(function(t) { t.classList.remove('active'); });
  document.querySelectorAll('.settings-panel').forEach(function(p) { p.classList.remove('active'); });
  var tabEl = document.querySelector('.settings-tab[data-tab="' + tab + '"]');
  var panelEl = document.getElementById('panel-' + tab);
  if (tabEl) tabEl.classList.add('active');
  if (panelEl) panelEl.classList.add('active');
  window.location.hash = tab;

  // Load data for the tab
  if (tab === 'blocklist') loadBlocklist();
  if (tab === 'audio') loadAudioFiles();
  if (tab === 'system') loadSystem();
}

// ═══════════════════ BLOCKLIST ═══════════════════
function showBlockAdd() {
  document.getElementById('bl-number').value = '';
  document.getElementById('bl-reason').value = '';
  document.getElementById('block-add').style.display = 'block';
}

async function loadBlocklist() {
  try {
    var d = await (await fetch(API + '/blocklist', { headers: H })).json();
    var b = document.getElementById('bl-body');
    if (d.success && d.blocked && d.blocked.length) {
      document.getElementById('bl-summary').textContent = d.blocked.length + ' blocked';
      b.innerHTML = d.blocked.map(function(n) {
        return '<tr>' +
          '<td class="mono" style="font-weight:500">' + esc(n.number) + '</td>' +
          '<td class="muted">' + esc(n.reason || '—') + '</td>' +
          '<td class="muted" style="font-size:11px">' + esc(n.blockedBy || '—') + '</td>' +
          '<td class="muted" style="font-size:11px">' + fmtTime(n.createdAt) + '</td>' +
          '<td><button class="btn btn-sm" onclick="unblock(\'' + esc(n.number) + '\')">Unblock</button></td>' +
        '</tr>';
      }).join('');
    } else {
      document.getElementById('bl-summary').textContent = '';
      b.innerHTML = '<tr><td colspan="5" class="empty">No blocked numbers</td></tr>';
    }
  } catch (e) { console.error('blocklist', e); }
}

async function addBlock(e) {
  e.preventDefault();
  var number = document.getElementById('bl-number').value.trim();
  var reason = document.getElementById('bl-reason').value.trim();
  var r = await fetch(API + '/blocklist', {
    method: 'POST', headers: J,
    body: JSON.stringify({ number: number, reason: reason, blockedBy: currentUser })
  });
  var d = await r.json();
  if (d.success) {
    document.getElementById('block-add').style.display = 'none';
    showToast(number + ' blocked');
    loadBlocklist();
  } else {
    showToast(d.error || 'Failed', true);
  }
}

async function unblock(number) {
  if (!confirm('Unblock ' + number + '?')) return;
  await fetch(API + '/blocklist/' + number, { method: 'DELETE', headers: H });
  showToast(number + ' unblocked');
  loadBlocklist();
}

// ═══════════════════ AUDIO FILES ═══════════════════
async function loadAudioFiles() {
  try {
    var d = await (await fetch(API + '/audio/list', { headers: H })).json();
    var b = document.getElementById('audio-body');
    if (d.success && d.files && d.files.length) {
      document.getElementById('audio-summary').textContent = d.files.length + ' file(s)';
      b.innerHTML = d.files.map(function(f) {
        return '<tr>' +
          '<td class="mono" style="font-size:12px">' + esc(f.name) + '</td>' +
          '<td class="muted">' + Math.round(f.size / 1024) + ' KB</td>' +
          '<td class="muted" style="font-size:11px">' + fmtTime(f.modified) + '</td>' +
          '<td style="white-space:nowrap">' +
            '<button class="act-btn" onclick="playAudio(\'' + esc(f.name) + '\',this)" title="Play">' +
              '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>' +
            '</button>' +
            '<button class="act-btn" onclick="renameAudio(\'' + esc(f.name) + '\')" title="Rename">' +
              '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
            '</button>' +
            '<button class="act-btn" onclick="deleteAudio(\'' + esc(f.name) + '\')" title="Delete">' +
              '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>' +
            '</button>' +
          '</td>' +
        '</tr>';
      }).join('');
    } else {
      document.getElementById('audio-summary').textContent = '';
      b.innerHTML = '<tr><td colspan="4" class="empty">No audio files</td></tr>';
    }
  } catch (e) { console.error('audio', e); }
}

var ICON_PLAY = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
var ICON_PAUSE = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>';
var currentAudio = null, currentBtn = null;

function playAudio(filename, btn) {
  if (currentAudio && currentBtn === btn) {
    if (currentAudio.paused) { currentAudio.play(); btn.innerHTML = ICON_PAUSE; btn.title = 'Pause'; }
    else { currentAudio.pause(); btn.innerHTML = ICON_PLAY; btn.title = 'Resume'; }
    return;
  }
  if (currentAudio) { currentAudio.pause(); if (currentBtn) { currentBtn.innerHTML = ICON_PLAY; currentBtn.title = 'Play'; } }
  var a = new Audio(API + '/audio/play/' + encodeURIComponent(filename));
  a.onended = function() { btn.innerHTML = ICON_PLAY; btn.title = 'Play'; currentAudio = null; currentBtn = null; };
  a.onerror = function() { btn.innerHTML = ICON_PLAY; showToast('Could not play', true); currentAudio = null; currentBtn = null; };
  a.play(); btn.innerHTML = ICON_PAUSE; btn.title = 'Pause'; currentAudio = a; currentBtn = btn;
}

async function renameAudio(oldName) {
  var baseName = oldName.replace(/\.[^.]+$/, '');
  var newName = prompt('Rename "' + oldName + '" to:', baseName);
  if (!newName || newName === baseName) return;
  var r = await fetch(API + '/audio/rename', { method: 'POST', headers: J, body: JSON.stringify({ oldName: oldName, newName: newName }) });
  var d = await r.json();
  if (d.success) { showToast('Renamed to ' + d.newName); loadAudioFiles(); }
  else showToast(d.error || 'Rename failed', true);
}

async function deleteAudio(filename) {
  if (!confirm('Delete "' + filename + '"?\n\nIf used by an IVR or MOH, it will stop working.')) return;
  var r = await fetch(API + '/audio/' + encodeURIComponent(filename), { method: 'DELETE', headers: H });
  var d = await r.json();
  if (d.success) { showToast(filename + ' deleted'); loadAudioFiles(); }
  else showToast(d.error || 'Delete failed', true);
}

async function uploadAudioFile(input) {
  if (!input.files || !input.files[0]) return;
  var formData = new FormData();
  formData.append('file', input.files[0]);
  try {
    var r = await fetch(API + '/audio/upload', { method: 'POST', headers: { 'X-API-Key': KEY }, body: formData });
    var d = await r.json();
    if (d.success) { showToast('Uploaded: ' + d.originalName + (d.warning ? ' (' + d.warning + ')' : '')); loadAudioFiles(); }
    else showToast(d.error || 'Upload failed', true);
  } catch (e) { showToast('Upload failed', true); }
  input.value = '';
}

// ═══════════════════ SYSTEM ═══════════════════
async function loadSystem() {
  try {
    var d = await (await fetch(API + '/health', { headers: H })).json();
    if (d.success) {
      var up = d.uptime || 0;
      var days = Math.floor(up / 86400);
      var hrs = Math.floor((up % 86400) / 3600);
      var mins = Math.floor((up % 3600) / 60);
      document.getElementById('sys-uptime').textContent = (days > 0 ? days + 'd ' : '') + hrs + 'h ' + mins + 'm';
    }
    document.getElementById('sys-time').textContent = new Date().toLocaleString();
  } catch (e) {}
}

// ─── Init: read hash and switch tab ───
var initTab = window.location.hash.replace('#', '') || 'blocklist';
if (['blocklist', 'audio', 'system'].indexOf(initTab) === -1) initTab = 'blocklist';
switchTab(initTab);
</script>
<%- include('../partials/foot') %>
