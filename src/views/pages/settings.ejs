async function loadDbStats() {
  try {
    var d = await (await fetch(API + '/settings/dbstats', { headers: H })).json();
    if (!d.success) return;
    var db = d.database;

    // Overview cards
    document.getElementById('db-total-size').textContent = db.totalSizeHuman;
    document.getElementById('db-total-detail').textContent = 'Data: ' + db.dataSizeHuman + ' + Indexes: ' + db.indexSizeHuman;
    document.getElementById('db-collections').textContent = db.collections;
    document.getElementById('db-collections-detail').textContent = 'Storage: ' + db.storageSizeHuman;
    document.getElementById('db-documents').textContent = db.totalDocuments.toLocaleString();
    document.getElementById('db-documents-detail').textContent = 'Across all collections';

    // Storage breakdown bar
    var total = db.dataSize + db.indexSize;
    if (total > 0) {
      var dataPct = Math.round((db.dataSize / total) * 100);
      var indexPct = 100 - dataPct;
      document.getElementById('db-bar-data').style.width = dataPct + '%';
      document.getElementById('db-bar-index').style.width = indexPct + '%';
      document.getElementById('db-breakdown-label').textContent = dataPct + '% data / ' + indexPct + '% indexes';
    }
    document.getElementById('db-data-size').textContent = db.dataSizeHuman;
    document.getElementById('db-index-size').textContent = db.indexSizeHuman;

    // Collections table
    var body = document.getElementById('db-collections-body');
    if (d.collections && d.collections.length) {
      var maxSize = Math.max.apply(null, d.collections.map(function(c) { return c.size || 0; })) || 1;
      body.innerHTML = d.collections.map(function(c) {
        var pct = Math.max(2, Math.round(((c.size || 0) / maxSize) * 100));
        return '<tr>' +
          '<td><span class="mono" style="font-size:12px;font-weight:500">' + esc(c.name) + '</span></td>' +
          '<td style="text-align:right;font-variant-numeric:tabular-nums">' + (c.documents || 0).toLocaleString() + '</td>' +
          '<td style="text-align:right;font-size:12px">' + (c.sizeHuman || '0 B') + '</td>' +
          '<td style="text-align:right;font-size:12px;color:var(--text-tertiary)">' + (c.avgObjSizeHuman || '0 B') + '</td>' +
          '<td style="text-align:right;font-variant-numeric:tabular-nums">' + (c.indexes || 0) + '</td>' +
          '<td style="text-align:right;font-size:12px">' + (c.indexSizeHuman || '0 B') + '</td>' +
          '<td><div class="db-bar"><div class="db-bar-fill" style="width:' + pct + '%"></div></div></td>' +
        '</tr>';
      }).join('');
    } else {
      body.innerHTML = '<tr><td colspan="7" class="empty">No collections found</td></tr>';
    }
  } catch (e) { console.error('dbstats', e); }
}

