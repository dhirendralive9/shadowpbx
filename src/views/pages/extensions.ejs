<%- include('../partials/head', { title: 'Extensions', active: 'extensions' }) %>

<div class="sec-head">
  <span class="sec-title">Extensions</span>
  <button class="btn btn-sm" onclick="showAddForm()">+ Add extension</button>
</div>

<div id="add-form" style="display:none; margin-bottom:16px;" class="card">
  <form onsubmit="addExtension(event)">
    <div class="grid-3" style="margin-bottom:0">
      <div class="form-group"><label class="form-label">Extension</label><input class="form-input" id="new-ext" placeholder="2004" required></div>
      <div class="form-group"><label class="form-label">Name</label><input class="form-input" id="new-name" placeholder="User Four" required></div>
      <div class="form-group"><label class="form-label">Password</label><input class="form-input" id="new-pass" placeholder="SIP password" required></div>
    </div>
    <div style="display:flex;gap:8px;margin-top:8px">
      <button type="submit" class="btn btn-primary btn-sm">Create</button>
      <button type="button" class="btn btn-sm" onclick="hideAddForm()">Cancel</button>
    </div>
  </form>
</div>

<table class="tbl">
  <thead><tr><th>Status</th><th>Extension</th><th>Name</th><th>User agent</th><th>IP address</th><th>Expires</th><th></th></tr></thead>
  <tbody id="ext-body">
    <tr><td colspan="7" class="empty">Loading...</td></tr>
  </tbody>
</table>

<script>
const API = '/api';
const KEY = '<%= apiKey %>';
const headers = { 'X-API-Key': KEY };

function showAddForm() { document.getElementById('add-form').style.display = 'block'; }
function hideAddForm() { document.getElementById('add-form').style.display = 'none'; }

async function loadExtensions() {
  const r = await fetch(API + '/extensions', { headers });
  const d = await r.json();
  if (!d.success) return;
  const tbody = document.getElementById('ext-body');
  if (!d.extensions.length) { tbody.innerHTML = '<tr><td colspan="7" class="empty">No extensions configured</td></tr>'; return; }
  tbody.innerHTML = d.extensions.map(e => {
    const reg = e.registrations && e.registrations.length > 0;
    const r0 = reg ? e.registrations[0] : {};
    return `<tr>
      <td><span class="dot ${reg ? 'dot-green' : 'dot-gray'}"></span></td>
      <td class="mono">${e.extension}</td>
      <td>${e.name || ''}</td>
      <td class="muted" style="font-size:11px">${r0.userAgent || '-'}</td>
      <td class="mono" style="font-size:11px">${reg ? r0.ip + ':' + r0.port : '-'}</td>
      <td class="muted">${r0.expires ? r0.expires + 's' : '-'}</td>
      <td><button class="act-btn" title="Delete" onclick="deleteExt('${e._id}','${e.extension}')">
        <svg viewBox="0 0 24 24" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
      </button></td>
    </tr>`;
  }).join('');
}

async function addExtension(e) {
  e.preventDefault();
  const body = {
    extension: document.getElementById('new-ext').value,
    name: document.getElementById('new-name').value,
    password: document.getElementById('new-pass').value
  };
  await fetch(API + '/extensions', {
    method: 'POST', headers: { ...headers, 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  hideAddForm();
  loadExtensions();
}

async function deleteExt(id, ext) {
  if (!confirm('Delete extension ' + ext + '?')) return;
  await fetch(API + '/extensions/' + id, { method: 'DELETE', headers });
  loadExtensions();
}

loadExtensions();
setInterval(loadExtensions, 10000);
</script>

<%- include('../partials/foot') %>
