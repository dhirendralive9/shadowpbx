<%- include('../partials/head', { title: 'Call history', active: 'cdr' }) %>
<div class="sec-head">
  <span class="sec-title">Call detail records</span>
</div>
<div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
  <input class="form-input" style="max-width:200px" id="search" placeholder="Search caller/ext...">
  <select class="form-select" style="max-width:140px" id="filter-status">
    <option value="">All statuses</option>
    <option value="answered">Answered</option>
    <option value="completed">Completed</option>
    <option value="missed">Missed</option>
    <option value="voicemail">Voicemail</option>
    <option value="failed">Failed</option>
  </select>
  <select class="form-select" style="max-width:140px" id="filter-dir">
    <option value="">All directions</option>
    <option value="inbound">Inbound</option>
    <option value="outbound">Outbound</option>
    <option value="internal">Internal</option>
  </select>
  <button class="btn btn-sm" onclick="loadCDR()">Search</button>
</div>
<table class="tbl">
  <thead><tr><th></th><th>From</th><th>To</th><th>Duration</th><th>Talk</th><th>Status</th><th>Recording</th><th>Time</th></tr></thead>
  <tbody id="cdr-body"><tr><td colspan="8" class="empty">Loading...</td></tr></tbody>
</table>
<div style="display:flex;justify-content:space-between;margin-top:12px;font-size:12px;color:var(--text-tertiary)">
  <span id="cdr-info">-</span>
  <div><button class="btn btn-sm" id="prev-btn" onclick="prevPage()" disabled>Prev</button> <button class="btn btn-sm" id="next-btn" onclick="nextPage()" disabled>Next</button></div>
</div>
<script>
const API='/api',KEY='<%= apiKey %>',H={'X-API-Key':KEY};
let page=1,limit=20;
function dur(s){if(!s)return'-';return String(Math.floor(s/60)).padStart(2,'0')+':'+String(s%60).padStart(2,'0')}
function fmtTime(t){if(!t)return'';const d=new Date(t);return d.toLocaleDateString([],{month:'short',day:'numeric'})+' '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}
function pillCls(s){if(['answered','completed'].includes(s))return'p-ok';if(s==='voicemail')return'p-vm';if(['missed','failed','busy'].includes(s))return'p-miss';return'p-gray'}
async function loadCDR(){
  const q=document.getElementById('search').value;
  const st=document.getElementById('filter-status').value;
  const dir=document.getElementById('filter-dir').value;
  let url=`/cdr?page=${page}&limit=${limit}`;
  if(q)url+=`&search=${encodeURIComponent(q)}`;
  if(st)url+=`&status=${st}`;
  if(dir)url+=`&direction=${dir}`;
  const d=await(await fetch(API+url,{headers:H})).json();
  const b=document.getElementById('cdr-body');
  if(d.success&&d.cdrs&&d.cdrs.length){
    b.innerHTML=d.cdrs.map(c=>`<tr>
      <td><span style="color:${c.direction==='inbound'?'var(--green)':'var(--blue)'}">${c.direction==='inbound'?'↓':'↑'}</span></td>
      <td>${c.from||'?'}</td><td>${c.to||'?'}</td>
      <td class="mono">${dur(c.duration)}</td><td class="mono">${dur(c.talkTime)}</td>
      <td><span class="pill ${pillCls(c.status)}">${c.status}</span></td>
      <td>${c.recordingPath ? '<button class="btn btn-sm" onclick="playRec(\''+c.callId+'\',this)" title="Play recording">&#9654;</button>' : '<span class="muted" style="font-size:10px">-</span>'}</td>
      <td class="muted" style="font-size:11px">${fmtTime(c.startTime)}</td>
    </tr>`).join('');
    const p=d.pagination;
    document.getElementById('cdr-info').textContent=`Showing ${(p.page-1)*limit+1}-${Math.min(p.page*limit,p.total)} of ${p.total}`;
    document.getElementById('prev-btn').disabled=p.page<=1;
    document.getElementById('next-btn').disabled=p.page>=p.pages;
  }else{b.innerHTML='<tr><td colspan="8" class="empty">No records found</td></tr>';document.getElementById('cdr-info').textContent='0 records';}
}
let currentAudio=null;
function playRec(callId,btn){
  if(currentAudio){currentAudio.pause();currentAudio=null;}
  const a=new Audio(API+'/cdr/'+callId+'/recording?_key='+KEY);
  a.onended=function(){btn.textContent='\u25B6';currentAudio=null;};
  a.onerror=function(){btn.textContent='\u25B6';alert('Recording not available');currentAudio=null;};
  a.play();btn.textContent='\u25A0';currentAudio=a;
}
function prevPage(){page--;loadCDR()}
function nextPage(){page++;loadCDR()}
document.getElementById('search').addEventListener('keypress',e=>{if(e.key==='Enter'){page=1;loadCDR()}});
loadCDR();
</script>
<%- include('../partials/foot') %>
