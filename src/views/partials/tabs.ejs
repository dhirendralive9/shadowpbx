// ─── Define nav structure ───
var navItems = [
  { id: 'dashboard',  label: 'Overview',    icon: 'grid',      href: '/',            roles: ['admin','supervisor','agent'] },
  { id: 'extensions', label: 'Extensions',  icon: 'users2',    href: '/extensions',  roles: ['admin','supervisor'] },
  { id: 'calls',      label: 'Calls',       icon: 'phone',     href: '/calls',       roles: ['admin','supervisor'] },
  { id: 'cdr',        label: 'CDR',         icon: 'filetext',  href: '/cdr',         roles: ['admin','supervisor','agent'] },
  { id: 'voicemail',  label: 'Voicemail',   icon: 'voicemail', href: '/voicemail',   roles: ['admin','supervisor','agent'] },
  { id: 'chat',       label: 'Chat',        icon: 'msgsquare', href: '/chat',        roles: ['admin','supervisor','agent'] },
  // ─── Call Flow dropdown ───
  { id: 'callflow', label: 'Call flow', icon: 'gitbranch', roles: ['admin','supervisor'], children: [
    { id: 'ringgroups',     label: 'Ring groups',      icon: 'ringgroup', href: '/ringgroups',      roles: ['admin','supervisor'] },
    { id: 'queues',         label: 'Queues',           icon: 'queue',     href: '/queues',          roles: ['admin','supervisor'] },
    { id: 'ivr',            label: 'IVR',              icon: 'ivr',       href: '/ivr',             roles: ['admin'] },
    { id: 'timeconditions', label: 'Time conditions',  icon: 'clock',     href: '/time-conditions', roles: ['admin'] },
    { id: 'appointments',   label: 'Appointments',     icon: 'calendar',  href: '/appointments',    roles: ['admin','supervisor'] },
  ]},
  // ─── Network dropdown ───
  { id: 'network', label: 'Network', icon: 'globe', roles: ['admin'], children: [
    { id: 'trunks', label: 'Trunks', icon: 'trunk', href: '/trunks', roles: ['admin'] },
    { id: 'routes', label: 'Routes', icon: 'route', href: '/routes', roles: ['admin'] },
  ]},
  // ─── Campaigns ───
  { id: 'campaigns', label: 'Campaigns', icon: 'megaphone', href: '/campaigns', roles: ['admin','supervisor'] },
  // ─── Settings dropdown ───
  { id: 'settingsmenu', label: 'Settings', icon: 'settings', roles: ['admin'], children: [
    { id: 'users',    label: 'Users',    icon: 'userscog', href: '/users',    roles: ['admin'] },
    { id: 'settings', label: 'Settings', icon: 'settings', href: '/settings', roles: ['admin'] },
  ]},
];

// Check if active tab is inside a dropdown
function isChildActive(item) {
  if (!item.children) return false;
  return item.children.some(function(c) { return c.id === active; });
}
%>

<nav class="tabs">
  <% navItems.forEach(function(item) { %>
    <% if (!item.roles.includes(r)) return; %>

    <% if (item.children) { %>
      <%
        // Filter children by role
        var visibleChildren = item.children.filter(function(c) { return c.roles.includes(r); });
        if (visibleChildren.length === 0) return;
        var dropActive = isChildActive(item);
      %>
      <div class="tab-dropdown">
        <a href="#" class="tab <%= dropActive ? 'active' : '' %>" onclick="event.preventDefault(); toggleDrop(this.parentNode)">
          <%- icons[item.icon] || '' %>
          <%= item.label %>
          <span class="tab-chev"><%- icons.chevdown %></span>
        </a>
        <div class="tab-drop-menu">
          <% visibleChildren.forEach(function(child) { %>
            <a href="<%= child.href %>" class="tab-drop-item <%= active === child.id ? 'active' : '' %>">
              <%- icons[child.icon] || '' %>
              <%= child.label %>
            </a>
          <% }); %>
        </div>
      </div>
    <% } else { %>
      <a href="<%= item.href %>" class="tab <%= active === item.id ? 'active' : '' %>">
        <%- icons[item.icon] || '' %>
        <%= item.label %>
      </a>
    <% } %>
  <% }); %>
</nav>

<style>
/* Dropdown container */
.tab-dropdown { position: relative; }
.tab-chev { display: inline-flex; }
.tab-chev svg { width: 12px; height: 12px; transition: transform 0.2s; }
.tab-dropdown.open .tab-chev svg { transform: rotate(180deg); }

/* Dropdown menu */
.tab-drop-menu {
  display: none; position: absolute; top: 100%; left: 0; z-index: 50;
  background: var(--bg-surface); border: 0.5px solid var(--border);
  border-radius: var(--radius); padding: 4px 0; min-width: 180px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  margin-top: 2px;
}
.tab-dropdown.open .tab-drop-menu { display: block; }

.tab-drop-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 14px; font-size: 13px;
  color: var(--text-secondary); text-decoration: none;
  transition: background 0.1s, color 0.1s;
}
.tab-drop-item:hover { background: var(--bg-tertiary); color: var(--text-primary); text-decoration: none; }
.tab-drop-item.active { color: var(--accent); }
.tab-drop-item svg { width: 14px; height: 14px; flex-shrink: 0; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
</style>

<script>
function toggleDrop(el) {
  // Close all other dropdowns
  document.querySelectorAll('.tab-dropdown.open').forEach(function(d) { if (d !== el) d.classList.remove('open'); });
  el.classList.toggle('open');
}
// Close dropdowns when clicking outside
document.addEventListener('click', function(e) {
  if (!e.target.closest('.tab-dropdown')) {
    document.querySelectorAll('.tab-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
  }
});
</script>
