  megaphone:   '<svg viewBox="0 0 24 24"><path d="M3 11l18-5v12L3 13v-2z"/><path d="M11.6 16.8a3 3 0 11-5.8-1.6"/></svg>',
  settings:    '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9c-.12-.62-.05-1.27.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06c.55.38 1.2.45 1.82.33.62-.12 1.14-.51 1.39-1.07V3a2 2 0 014 0v.09c.25.56.77.95 1.39 1.07.62.12 1.27.05 1.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06c-.38.55-.45 1.2-.33 1.82.12.62.51 1.14 1.07 1.39H21a2 2 0 010 4h-.09c-.56.25-.95.77-1.07 1.39z"/></svg>',
  // Sub-menu icons
  ringgroup:   '<svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
