<% var cfr = typeof role !== 'undefined' ? role : 'admin'; %>
<div class="sub-tabs">
<% if (['admin','supervisor'].includes(cfr)) { %>
  <a href="/ringgroups" class="sub-tab <%= cfActive === 'ringgroups' ? 'active' : '' %>">Ring groups</a>
  <a href="/queues" class="sub-tab <%= cfActive === 'queues' ? 'active' : '' %>">Queues</a>
<% } %>
<% if (cfr === 'admin') { %>
  <a href="/ivr" class="sub-tab <%= cfActive === 'ivr' ? 'active' : '' %>">IVR</a>
  <a href="/time-conditions" class="sub-tab <%= cfActive === 'timeconditions' ? 'active' : '' %>">Time conditions</a>
<% } %>
<% if (['admin','supervisor'].includes(cfr)) { %>
  <a href="/appointments" class="sub-tab <%= cfActive === 'appointments' ? 'active' : '' %>">Appointments</a>
<% } %>
</div>
