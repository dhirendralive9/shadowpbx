<header class="header">
  <div class="brand">
    <div class="brand-mark"></div>
    <span class="brand-name">ShadowPBX</span>
    <span class="brand-tag">v2.0</span>
  </div>
  <div class="header-spacer"></div>
  <div class="header-status"><span class="header-dot"></span> Online</div>
  <% if (typeof role !== 'undefined' && role) { %>
    <span class="pill <%= role === 'admin' ? 'p-miss' : role === 'supervisor' ? 'p-warn' : 'p-info' %>" style="margin-left:12px;font-size:9px"><%= role %></span>
  <% } %>
  <span class="header-user"><%= typeof userName !== 'undefined' && userName ? userName : (typeof user !== 'undefined' ? user : 'admin') %></span>
  <a href="/logout" class="header-logout">Sign out</a>
</header>
