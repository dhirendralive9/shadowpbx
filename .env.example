# ShadowPBX Configuration
# Copy to .env and edit values

# Drachtio Server
DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=change_me

# SIP Settings
SIP_DOMAIN=your-domain-or-ip
SIP_PORT=5060
EXTERNAL_IP=your-server-ip

# RTPEngine
RTPENGINE_HOST=127.0.0.1
RTPENGINE_PORT=22222

# MongoDB (authenticated)
MONGODB_URI=mongodb://shadowpbx:change_me@127.0.0.1:27017/shadowpbx?authSource=shadowpbx

# Recordings
RECORDINGS_DIR=/var/lib/shadowpbx/recordings
RECORDING_FORMAT=wav

# Express API
API_PORT=3000
ADMIN_SECRET=change_me

# Security
MAX_REGISTER_ATTEMPTS=5
REGISTER_BAN_DURATION=300
SIP_RATE_LIMIT=20
LOG_LEVEL=info
