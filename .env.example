# ShadowPBX Configuration
# Copy to .env and edit values

# Drachtio Server
DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=change_me

# SIP Settings
SIP_DOMAIN=your-domain-or-ip
SIP_PORT=5060
EXTERNAL_IP=your-server-ip

# RTPEngine
RTPENGINE_HOST=127.0.0.1
RTPENGINE_PORT=22222

# MongoDB (authenticated)
MONGODB_URI=mongodb://shadowpbx:change_me@127.0.0.1:27017/shadowpbx?authSource=shadowpbx

# Recordings
RECORDINGS_DIR=/var/lib/shadowpbx/recordings
RECORDING_FORMAT=wav

# Express API
API_PORT=3000
ADMIN_SECRET=change_me

# Security
MAX_REGISTER_ATTEMPTS=5
REGISTER_BAN_DURATION=300
SIP_RATE_LIMIT=20
LOG_LEVEL=info

# Appointment Webhooks (Twilio/SignalWire/Telnyx)
# Public URL where carriers can reach your server
# WEBHOOK_BASE_URL=https://your-domain.com

# Carrier API Credentials (for AMD-enabled dialer campaigns)
# TELNYX_API_KEY=KEYxxxxxxxx
# TELNYX_CONNECTION_ID=1494404757140276705
# SIGNALWIRE_PROJECT_ID=your-project-id
# SIGNALWIRE_API_TOKEN=your-api-token
# SIGNALWIRE_SPACE=your-space.signalwire.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
