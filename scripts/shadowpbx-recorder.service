[Unit]
Description=ShadowPBX Recording Worker
After=network.target mongod.service docker.service shadowpbx.service
Wants=shadowpbx.service

[Service]
Type=simple
WorkingDirectory=/opt/shadowpbx
ExecStart=/usr/bin/node src/recorder-worker.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production
StandardOutput=append:/var/log/shadowpbx/recorder.log
StandardError=append:/var/log/shadowpbx/recorder-error.log

[Install]
WantedBy=multi-user.target
